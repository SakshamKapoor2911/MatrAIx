# Local seed-run config. Copy to .env and adjust. The 25-agent science run is local;
# AWS comes later (see infra/). The reference agent's LLM key is PARTICIPANT-side only —
# the engine never calls an LLM on the hot path.

# Local Postgres (docker-compose.yml)
DATABASE_URL=postgresql://mircoverse:mircoverse@localhost:5432/mircoverse
TEST_DATABASE_URL=postgresql://mircoverse:mircoverse@localhost:5432/mircoverse_test

# Tick clock (seconds). 30-60s in Architecture.md; tune to observed LLM latency.
TICK_INTERVAL=30

# Reference-agent LLM keys (participant-side; only needed to RUN agents, not the engine).
# The brain provider is selected at run time (scripts/run_local_llm.py): claude | oai |
# aws | other. Only the key(s) for the provider you actually use need a value.

# Which provider + model the reference-agent brain uses (CLI flags override these).
# MIRCOVERSE_LLM_PROVIDER=claude
# MIRCOVERSE_LLM_MODEL=claude-3-5-sonnet-20241022

# Anthropic (provider: claude)
# ANTHROPIC_API_KEY=

# OpenAI (provider: oai)
# OPENAI_API_KEY=

# OpenAI-compatible endpoint (provider: other — ollama/groq/together/openrouter/...).
# Needs a base URL; the SDK still wants *some* api key (use a dummy for local servers).
# OPENAI_BASE_URL=http://localhost:11434/v1

# AWS Bedrock (provider: aws). Uses the standard AWS credential chain (env / profile /
# instance role); set the region the model is available in.
# AWS_REGION=us-east-1
