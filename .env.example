# API key variable names for MatrAIx persona agents (set in your shell, e.g. ~/.zshrc).
# See docs/environments/choosing-an-agent.md for which agent needs which variable.
# Do not commit real keys — a local .env is gitignored if you use one for yourself.
# persona-claude-code (Anthropic)
ANTHROPIC_API_KEY=

# persona-openhands-sdk (Playwright web) — not ANTHROPIC_API_KEY
LLM_API_KEY=
# Optional proxy:
# LLM_BASE_URL=

# persona-browser-use / persona-cocoa (also accept LLM_API_KEY as fallback)
# ANTHROPIC_API_KEY is set above for persona-claude-code

# persona-computer-1 (CUA / use-computer)
USE_COMPUTER_API_KEY=
