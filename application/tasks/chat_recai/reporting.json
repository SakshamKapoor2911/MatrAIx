{
  "schemaVersion": "1.0",
  "contextRules": [
    {
      "match": {
        "contextType": "task_outcome"
      },
      "distributions": [
        {
          "id": "task_outcome.status_by_segment",
          "facetKey": "outcome_status",
          "title": "Outcome status"
        }
      ]
    },
    {
      "match": {
        "contextType": "recommendation_delivery"
      },
      "distributions": [
        {
          "id": "recommendation_delivery.adaptation_by_segment",
          "facetKey": "recommendation_adaptation",
          "title": "Recommendation adaptation"
        }
      ]
    },
    {
      "match": {
        "contextType": "user_feedback"
      },
      "distributions": [
        {
          "id": "user_feedback.preference_by_segment",
          "facetKey": "personal_preference_satisfaction",
          "title": "Personal preference satisfaction"
        },
        {
          "id": "user_feedback.rating_by_segment",
          "facetKey": "overall_experience_rating",
          "title": "Overall experience rating"
        }
      ]
    }
  ]
}
