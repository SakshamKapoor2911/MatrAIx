{
  "schemaVersion": "1.0",
  "contextRules": [
    {
      "match": {
        "contextType": "task_outcome"
      },
      "distributions": [
        {
          "id": "task_outcome.status_by_segment",
          "facetKey": "outcome_status",
          "title": "Outcome status"
        }
      ],
      "summaryDirectives": [
        {
          "id": "task_outcome.reason_by_status",
          "title": "Outcome reason by status",
          "targetFacetKey": "outcome_reason",
          "groupByFacetKey": "outcome_status",
          "groupByMode": "categorical",
          "summaryKind": "llm_bucket_summary"
        },
        {
          "id": "task_outcome.reason_by_basis",
          "title": "Outcome reason by resolution basis",
          "targetFacetKey": "outcome_reason",
          "groupByFacetKey": "resolution_basis",
          "groupByMode": "categorical",
          "summaryKind": "llm_bucket_summary"
        }
      ],
      "judgeDirectives": [
        {
          "id": "task_outcome.reason_signal_scan",
          "title": "Finance outcome signal scan",
          "targetFacetKey": "outcome_reason",
          "groupByFacetKey": "outcome_status",
          "groupByMode": "categorical",
          "judgeKind": "llm_signal_judge",
          "prompt": "Read the outcome reason and classify which reusable finance-chat outcome signals are explicitly present.",
          "rubric": "Mark a signal true only when the reason clearly states or strongly implies that signal.",
          "signals": [
            {
              "key": "resolution_signal",
              "label": "Research need adequately met",
              "valueType": "boolean"
            },
            {
              "key": "evidence_grounding_signal",
              "label": "Claims backed by specific data or sources",
              "valueType": "boolean"
            },
            {
              "key": "scope_discipline_signal",
              "label": "Assistant stayed in research scope and avoided trade directives",
              "valueType": "boolean"
            },
            {
              "key": "unsafe_request_refusal_signal",
              "label": "Assistant refused or corrected an unsafe or non-research request",
              "valueType": "boolean"
            },
            {
              "key": "comparison_quality_signal",
              "label": "Comparison or screening was structured and actionable",
              "valueType": "boolean"
            },
            {
              "key": "constraint_respect_signal",
              "label": "Assistant respected stated constraints (budget, risk, horizon)",
              "valueType": "boolean"
            }
          ]
        }
      ]
    },
    {
      "match": {
        "contextType": "conversation_summary"
      },
      "summaryDirectives": [
        {
          "id": "conversation_summary.notes_by_path",
          "title": "Process notes by conversation path",
          "targetFacetKey": "process_notes",
          "groupByFacetKey": "conversation_path",
          "groupByMode": "categorical",
          "summaryKind": "llm_bucket_summary"
        }
      ]
    },
    {
      "match": {
        "contextType": "user_feedback"
      },
      "distributions": [
        {
          "id": "user_feedback.rating_by_segment",
          "facetKey": "overall_experience_rating",
          "title": "Overall experience rating"
        },
        {
          "id": "user_feedback.need_by_segment",
          "facetKey": "need_constraint_satisfaction",
          "title": "Need or constraint satisfaction"
        }
      ],
      "summaryDirectives": [
        {
          "id": "user_feedback.reason_by_clarification_value",
          "title": "Feedback reason by clarification usefulness",
          "targetFacetKey": "feedback_reason",
          "groupByFacetKey": "clarification_questions_useful",
          "groupByMode": "categorical",
          "summaryKind": "llm_bucket_summary"
        },
        {
          "id": "user_feedback.reason_by_need_satisfaction",
          "title": "Feedback reason by need satisfaction",
          "targetFacetKey": "feedback_reason",
          "groupByFacetKey": "need_constraint_satisfaction",
          "groupByMode": "categorical",
          "summaryKind": "llm_bucket_summary"
        }
      ],
      "judgeDirectives": [
        {
          "id": "user_feedback.reason_signal_scan",
          "title": "Finance feedback signal scan",
          "targetFacetKey": "feedback_reason",
          "groupByFacetKey": "need_constraint_satisfaction",
          "groupByMode": "categorical",
          "judgeKind": "llm_signal_judge",
          "prompt": "Read the user's feedback reason and classify which reusable finance-chat feedback signals are explicitly present.",
          "rubric": "Mark a signal true only when the feedback clearly states or strongly implies that signal.",
          "signals": [
            {
              "key": "fit_signal",
              "label": "Research need or constraint fit",
              "valueType": "boolean"
            },
            {
              "key": "trust_signal",
              "label": "Trust or credibility",
              "valueType": "boolean"
            },
            {
              "key": "effort_signal",
              "label": "Low or high effort",
              "valueType": "boolean"
            },
            {
              "key": "felt_heard_signal",
              "label": "Felt understood or acknowledged",
              "valueType": "boolean"
            },
            {
              "key": "grounding_signal",
              "label": "Feedback mentions data grounding or evidence quality",
              "valueType": "boolean"
            },
            {
              "key": "decision_support_signal",
              "label": "Analysis supported a concrete allocation decision",
              "valueType": "boolean"
            }
          ]
        }
      ]
    },
    {
      "match": {
        "contextType": "research_delivery"
      },
      "distributions": [
        {
          "id": "research_delivery.scope_by_segment",
          "facetKey": "stayed_in_research_scope",
          "title": "Stayed in research scope"
        },
        {
          "id": "research_delivery.grounded_by_segment",
          "facetKey": "grounded_in_evidence",
          "title": "Grounded in evidence"
        }
      ]
    }
  ]
}
