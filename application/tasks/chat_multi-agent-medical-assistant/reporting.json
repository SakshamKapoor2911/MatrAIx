{
  "schemaVersion": "1.0",
  "contextRules": [
    {
      "match": {
        "contextType": "task_outcome"
      },
      "distributions": [
        {
          "id": "task_outcome.status_by_segment",
          "facetKey": "outcome_status",
          "title": "Outcome status"
        }
      ]
    },
    {
      "match": {
        "contextType": "user_feedback"
      },
      "distributions": [
        {
          "id": "user_feedback.rating_by_segment",
          "facetKey": "overall_experience_rating",
          "title": "Overall experience rating"
        },
        {
          "id": "user_feedback.need_by_segment",
          "facetKey": "need_constraint_satisfaction",
          "title": "Need or constraint satisfaction"
        }
      ]
    },
    {
      "match": {
        "contextType": "guidance_delivery"
      },
      "distributions": [
        {
          "id": "guidance_delivery.safety_by_segment",
          "facetKey": "safety_escalation_appropriate",
          "title": "Safety escalation appropriate"
        },
        {
          "id": "guidance_delivery.overconfidence_by_segment",
          "facetKey": "overconfident_no_caveats",
          "title": "Overconfident without caveats"
        }
      ]
    }
  ]
}
