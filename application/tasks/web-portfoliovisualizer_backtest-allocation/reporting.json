        }
      ]
    },
    {
      "match": { "contextType": "user_feedback" },
      "distributions": [
        {
          "id": "user_feedback.satisfaction_by_segment",
          "facetKey": "satisfaction",
          "title": "Satisfaction"
        },
        {
          "id": "user_feedback.goal_alignment_by_segment",
          "facetKey": "goal_alignment",
          "title": "Goal alignment"
        }
      ]
    }
  ]
