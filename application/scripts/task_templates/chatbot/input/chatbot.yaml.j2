transport: sidecar_http
runtimeDefaults:
  applicationId: {application_id}
  applicationContext: {application_context}
  domain: {domain}
connection:
  baseUrl: http://chat-sim:8000
  healthPath: /health
protocol:
  sendMessage:
    method: POST
    path: /v1/messages
    sessionIdField: ""
    messageField: message
    titleField: ""
    botTypeField: ""
    staticBody: {}
  response:
    sessionIdField: ""
    replyField: reply
artifacts:
  transcript: transcript.json
  applicationResult: application_result.json
  feedback: user_feedback.json
