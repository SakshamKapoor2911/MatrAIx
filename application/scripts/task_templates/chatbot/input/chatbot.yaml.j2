transport: sidecar_http
runtimeDefaults:
  applicationId: {application_id}
  applicationContext: {application_context}
  domain: {domain}
capabilities:
{capabilities}
connection:
  baseUrlEnv: {base_url_env}
  baseUrl: http://{sidecar_host}:8000
  healthPath: /health
protocol:
  sendMessage:
    method: POST
    path: /v1/messages
    sessionIdField: ""
    messageField: message
    titleField: ""
    botTypeField: ""
    staticBody: {}
  response:
    sessionIdField: ""
    replyField: reply
    turnField: turn
personaExposure:
  fields: {persona_exposure_fields}
artifacts:
  transcript: transcript.json
  applicationResult: application_result.json
  feedback: user_feedback.json
