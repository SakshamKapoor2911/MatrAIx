#!/bin/bash
#SBATCH -p seas_compute
#SBATCH -n 1
#SBATCH -c 1
#SBATCH --mem=16G
#SBATCH -t 0-04:00
#SBATCH -o sbatch_logs/%x_%A_%a.out
#SBATCH -e sbatch_logs/%x_%A_%a.err
#SBATCH --mail-type=FAIL
#SBATCH --mail-user=xiaominli@g.harvard.edu

set -euo pipefail

REPO_ROOT="${REPO_ROOT:-/n/netscratch/lu_lab/Lab/xiaominli/LLMResearch/MatrAIx}"
PYTHON_BIN="${PYTHON_BIN:-/n/home08/xiaominli/.conda/envs/env05/bin/python}"
MANIFEST="${MANIFEST:?MANIFEST is required}"
TASK_ID="${SLURM_ARRAY_TASK_ID:?This job must run as an array}"

output=$(sed -n "$((TASK_ID + 1))p" "$MANIFEST" | "$PYTHON_BIN" -c 'import json,sys; print(json.load(sys.stdin)["output"])')
if [[ -s "$output" && -s "${output%.npz}.json" ]]; then
  echo "SKIP existing output: $output"
  exit 0
fi

cd "$REPO_ROOT"
echo "date=$(date -Is) host=$(hostname) task=$TASK_ID"
PYTHONPATH="$REPO_ROOT" "$PYTHON_BIN" \
  persona/post_process/deduplication/scan_human_minhash.py \
  --manifest "$MANIFEST" \
  --task-index "$TASK_ID"