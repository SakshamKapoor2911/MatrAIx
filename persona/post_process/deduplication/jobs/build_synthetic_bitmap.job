#!/bin/bash
#SBATCH -p seas_compute
#SBATCH -n 1
#SBATCH -c 1
#SBATCH --mem=4G
#SBATCH -t 0-02:00
#SBATCH -o sbatch_logs/%x_%A_%a.out
#SBATCH -e sbatch_logs/%x_%A_%a.err
set -euo pipefail
R="${REPO_ROOT:?}"; S="${SLURM_ARRAY_TASK_ID:?}"; printf -v T "%04d" "$S"; cd "$R"; PYTHONPATH="$R" "$PYTHON_BIN" persona/post_process/deduplication/build_synthetic_bitmap.py --shard "$S" --quality "$R/persona/post_process/quality_filter/results/full_filter_20260719/synthetic/full_dag_100000000_shard_$T.reject.bits" --reduced "$REDUCED" --cutoff "$CUTOFF" --out "$OUTPUT/shard_$T.reject.bits"