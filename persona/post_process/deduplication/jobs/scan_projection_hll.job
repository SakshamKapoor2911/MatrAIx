#!/bin/bash
#SBATCH -p seas_compute
#SBATCH -n 1
#SBATCH -c 1
#SBATCH --mem=8G
#SBATCH -t 0-04:00
#SBATCH -o sbatch_logs/%x_%A_%a.out
#SBATCH -e sbatch_logs/%x_%A_%a.err
#SBATCH --mail-type=FAIL
#SBATCH --mail-user=xiaominli@g.harvard.edu

set -euo pipefail

REPO_ROOT="${REPO_ROOT:-/n/netscratch/lu_lab/Lab/xiaominli/LLMResearch/MatrAIx}"
PYTHON_BIN="${PYTHON_BIN:-/n/home08/xiaominli/.conda/envs/env05/bin/python}"
CONFIG="${CONFIG:?CONFIG is required}"
OUTPUT_DIR="${OUTPUT_DIR:?OUTPUT_DIR is required}"
TASK_ID="${SLURM_ARRAY_TASK_ID:?This job must run as an array}"

printf -v SHARD_TAG "%04d" "$TASK_ID"
source="$REPO_ROOT/persona/synthesis/generated/full_dag_10b_20260703/shards/full_dag_100000000_shard_${SHARD_TAG}.codes.gz"
reject="$REPO_ROOT/persona/post_process/quality_filter/results/full_filter_20260719/synthetic/full_dag_100000000_shard_${SHARD_TAG}.reject.bits"
out="$OUTPUT_DIR/shard_${SHARD_TAG}.npz"

if [[ -s "$out" && -s "${out%.npz}.json" ]]; then
  echo "SKIP existing output: $out"
  exit 0
fi

cd "$REPO_ROOT"
echo "date=$(date -Is) host=$(hostname) shard=$SHARD_TAG"
PYTHONPATH="$REPO_ROOT" "$PYTHON_BIN" \
  persona/post_process/deduplication/scan_projection_hll.py \
  --source "$source" \
  --rejection-bitmap "$reject" \
  --config "$CONFIG" \
  --out "$out"