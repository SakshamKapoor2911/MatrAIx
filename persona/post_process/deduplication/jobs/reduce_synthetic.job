#!/bin/bash
#SBATCH -p seas_compute
#SBATCH -n 1
#SBATCH -c 1
#SBATCH --mem=32G
#SBATCH -t 0-04:00
#SBATCH -o sbatch_logs/%x_%A_%a.out
#SBATCH -e sbatch_logs/%x_%A_%a.err
set -euo pipefail
R="${REPO_ROOT:?}"; cd "$R"; PYTHONPATH="$R" "$PYTHON_BIN" persona/post_process/deduplication/reduce_synthetic_partition.py --partition "${SLURM_ARRAY_TASK_ID:?}" --input "$INPUT" --out "$OUTPUT"