#!/bin/bash
#SBATCH --partition=seas_compute
#SBATCH --cpus-per-task=4
#SBATCH --mem=16G
#SBATCH --time=1-00:00:00
#SBATCH --output=sbatch_logs/coreset_upload_%j.out
#SBATCH --error=sbatch_logs/coreset_upload_%j.err
set -euo pipefail
[[ -n "${HF_TOKEN_matraix:-${HF_TOKEN:-}}" ]] || { echo "HF token is not exported" >&2; exit 2; }
export HF_TOKEN="${HF_TOKEN_matraix:-${HF_TOKEN:-}}"
"${HF_BIN:?}" upload-large-folder "${REPO_ID:?}" "${OUTPUT:?}" --repo-type dataset --num-workers 8