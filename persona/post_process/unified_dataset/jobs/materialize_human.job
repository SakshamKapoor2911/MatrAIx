#!/bin/bash
#SBATCH -p seas_compute
#SBATCH -n 1
#SBATCH -c 2
#SBATCH --mem=16G
#SBATCH -t 0-12:00
#SBATCH -o sbatch_logs/%x_%A_%a.out
#SBATCH -e sbatch_logs/%x_%A_%a.err
#SBATCH --mail-type=FAIL
#SBATCH --mail-user=xiaominli@g.harvard.edu
set -euo pipefail

R="${REPO_ROOT:?}"
TASK="${SLURM_ARRAY_TASK_ID:?}"
printf -v T "%04d" "$TASK"
REPORT="$OUTPUT/reports/human_$T.json"
mkdir -p "$OUTPUT/data" "$OUTPUT/reports"
cd "$R"
PYTHONPATH="$R" "$PYTHON_BIN" -m persona.post_process.unified_dataset.materialize human \
  --manifest "$MANIFEST" --dedup-dir "$DEDUP_DIR" --schema "$SCHEMA" \
  --task "$TASK" --batch-rows 64 --rows-per-file 5000000 --row-group-size 100000 \
  --output-dir "$OUTPUT/data" --report "$REPORT"