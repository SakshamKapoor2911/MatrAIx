#!/bin/bash
#SBATCH -p seas_gpu
#SBATCH --gres=gpu:nvidia_a100-sxm4-80gb:2
#SBATCH -n 1
#SBATCH -c 32
#SBATCH --mem=160G
#SBATCH -t 2-00:00
#SBATCH -o sbatch_logs/%x_%A_%a.out
#SBATCH -e sbatch_logs/%x_%A_%a.err
#SBATCH --mail-type=FAIL
#SBATCH --mail-user=xiaominli@g.harvard.edu
#
# Amazon persona extraction — one array task = one user_bucket = 2x A100 80GB.
# 256 buckets (00..ff), ~390 selected users each. shard-id == array index maps to
# the hex bucket. Two 80 GB cards (160 GB) hold the 35B MoE in full bf16 (~70 GB)
# with ample KV-cache headroom via tensor parallelism — no quantization needed.
# Runs on seas_gpu (2-day cap) where we have priority; ~390 users/shard is well
# under that.
#
#   cd persona/human_extraction/jobs
#   mkdir -p sbatch_logs
#   sbatch --array=0-255%16 extract_shard_amazon.job          # full run
#   sbatch --array=0%1 --export=ALL,LIMIT=8 extract_shard_amazon.job  # smoke test
#
# Resumable: run_extraction_amazon.py appends to shard_<bkt>.jsonl and skips
# user_id already written; re-run the same sbatch line to top up unfinished shards.

set -uo pipefail

mamba init >/dev/null 2>&1 || true
module load python/3.10.13-fasrc01
module load cuda/12.4.1-fasrc01
conda activate env05

REPO_ROOT="/n/netscratch/lu_lab/Lab/xiaominli/LLMResearch/MatrAIx"
PY="/n/home08/xiaominli/.conda/envs/env05/bin/python"

# --- caches on netscratch (never home) ---
export HF_HOME="/n/netscratch/lu_lab/Lab/xiaominli/mycache/hf_home"
export HF_HUB_CACHE="$HF_HOME/hub"
export HF_XET_CACHE="$HF_HOME/xet"
export VLLM_CACHE_ROOT="/n/netscratch/lu_lab/Lab/xiaominli/mycache/vllm"
export VLLM_WORKER_MULTIPROC_METHOD=spawn
mkdir -p "$VLLM_CACHE_ROOT" sbatch_logs

SHARD_ID="${SLURM_ARRAY_TASK_ID:-${SHARD_ID:-0}}"
OUT_DIR="${OUT_DIR:-$REPO_ROOT/persona/human_extraction/data/amazon/extraction_v1}"
QUANT="${QUANT:-none}"
TP="${TP:-2}"
LIMIT="${LIMIT:-0}"

echo "=== amazon persona extraction shard ==="
echo "date=$(date -Is)  host=$(hostname)"
echo "shard_id=$SHARD_ID  bucket=$(printf '%02x' "$SHARD_ID")  out_dir=$OUT_DIR  tp=$TP  quant=$QUANT  limit=$LIMIT"
echo "slurm_job=${SLURM_JOB_ID:-none}  array_task=${SLURM_ARRAY_TASK_ID:-none}"
nvidia-smi --query-gpu=name,memory.total,driver_version --format=csv,noheader | head -2

cd "$REPO_ROOT"
start=$(date +%s)
"$PY" -u persona/human_extraction/scripts/run_extraction_amazon.py \
    --shard-id "$SHARD_ID" \
    --out-dir "$OUT_DIR" \
    --tensor-parallel "$TP" \
    --quantization "$QUANT" \
    --limit "$LIMIT"
rc=$?
echo "DONE shard=$SHARD_ID rc=$rc elapsed=$(( $(date +%s) - start ))s"
exit $rc
